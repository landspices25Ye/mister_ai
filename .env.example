# Mister AI - Environment Variables Example (v2.1)
# انسخ هذا الملف إلى .env واملأ القيم الفعلية

# ===== LLM Provider =====
# اختر المزود: "gemini" أو "openai"
LLM_PROVIDER=gemini

# ===== Telegram Bot =====
TELEGRAM_BOT_TOKEN=***

# ===== Google Gemini (الافتراضي) =====
GOOGLE_API_KEY=***
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=models/embedding-2

# ===== OpenAI (اختياري) =====
OPENAI_API_KEY=***
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===== PostgreSQL =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mister_ai_user
POSTGRES_PASSWORD=***
POSTGRES_DB=mister_ai

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379

# ===== Qdrant =====
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=mister_ai_curriculum

# ===== RAG Settings =====
RAG_TOP_K=4
RAG_SCORE_THRESHOLD=0.7
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# ===== LLM Settings =====
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
LLM_TIMEOUT=30

# ===== System Prompt =====
SYSTEM_PROMPT_PATH=/app/prompts/system_prompt.md

# ===== App Settings =====
LOG_LEVEL=INFO
ENVIRONMENT=production
